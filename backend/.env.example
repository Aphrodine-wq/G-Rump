# Qwen on Alibaba Cloud (DashScope) — required for chat + embeddings.
# Get a key from Alibaba Cloud Model Studio. https://www.alibabacloud.com/help/en/model-studio/
QWEN_API_KEY=sk-...

# DashScope OpenAI-compatible base URL.
# International accounts (default):
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# Mainland China accounts: https://dashscope.aliyuncs.com/compatible-mode/v1

# Embedding model for the desktop app's semantic memory.
QWEN_EMBED_MODEL=text-embedding-v4

# Shared bearer token the desktop app must send (Authorization: Bearer <APP_API_KEY>).
# Leave unset for local dev (gate open). REQUIRED in production.
APP_API_KEY=change-me-to-a-long-random-string

# Restrict CORS in production (comma-separated origins). Open in dev if unset.
# CORS_ORIGIN=https://your-domain

# Port (default 3042).
# PORT=3042
